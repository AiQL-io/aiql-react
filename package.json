{
  "name": "@aiql.io/react",
  "version": "0.1.7",
  "description": "React SDK for embedding AiQL components",
  "license": "MIT",
  "author": {
    "name": "AiQL",
    "url": "https://aiql.io"
  },
  "homepage": "https://docs.aiql.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AiQL-io/aiql-react.git"
  },
  "bugs": {
    "url": "https://github.com/AiQL-io/aiql-react/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "aiql",
    "react",
    "embed",
    "knowledge graph",
    "knowledge management",
    "graph",
    "rag"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js",
      "require": "./dist/server/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18"
  }
}
